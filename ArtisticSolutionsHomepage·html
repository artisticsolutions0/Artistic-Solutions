<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Artistic Solutions</title>
  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#0b1220;
      color:#fff;
      line-height:1.6;
    }

    header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:20px 60px;
      background:#0f172a;
      position:sticky;
      top:0;
      z-index:1000;
      border-bottom:1px solid #1f2937;
    }

    .logo{
      font-size:22px;
      font-weight:bold;
      color:#38bdf8;
    }

    nav a{
      color:#fff;
      margin-left:20px;
      text-decoration:none;
      transition:0.3s;
    }

    nav a:hover{
      color:#38bdf8;
    }

    .hero{
      height:90vh;
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      text-align:center;
      padding:20px;
      background:linear-gradient(135deg,#0f172a,#111827,#0b1220);
    }

    .hero h1{
      font-size:52px;
      max-width:900px;
    }

    .hero p{
      margin-top:15px;
      font-size:18px;
      color:#cbd5e1;
      max-width:600px;
    }

    .btn{
      margin-top:25px;
      padding:14px 28px;
      background:#38bdf8;
      color:#000;
      border:none;
      border-radius:8px;
      font-weight:bold;
      text-decoration:none;
      transition:0.3s;
    }

    .btn:hover{
      background:#0ea5e9;
    }

    .section{
      padding:70px 20px;
      text-align:center;
    }

    .section h2{
      font-size:32px;
      margin-bottom:20px;
      color:#38bdf8;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:20px;
      margin-top:30px;
      max-width:1000px;
      margin-left:auto;
      margin-right:auto;
    }

    .card{
      background:#111827;
      padding:20px;
      border-radius:10px;
      transition:0.3s;
      border:1px solid #1f2937;
    }

    .card:hover{
      transform:translateY(-5px);
      border-color:#38bdf8;
    }

    .portfolio{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:15px;
      margin-top:30px;
      max-width:1000px;
      margin-left:auto;
      margin-right:auto;
    }

    .work{
      background:#1f2937;
      height:150px;
      border-radius:10px;
      display:flex;
      justify-content:center;
      align-items:center;
      color:#94a3b8;
    }

    .contact-box{
      max-width:500px;
      margin:0 auto;
      background:#111827;
      padding:25px;
      border-radius:10px;
      border:1px solid #1f2937;
    }

    input,textarea{
      width:100%;
      padding:10px;
      margin-top:10px;
      margin-bottom:15px;
      border:none;
      border-radius:6px;
    }

    textarea{
      height:100px;
    }

    footer{
      text-align:center;
      padding:20px;
      background:#0f172a;
      border-top:1px solid #1f2937;
      color:#94a3b8;
    }

    .whatsapp{
      position:fixed;
      bottom:20px;
      right:20px;
      background:#25D366;
      color:#fff;
      padding:12px 16px;
      border-radius:50px;
      text-decoration:none;
      font-weight:bold;
    }
  </style>
</head>
<body>

<header>
  <div class="logo">Artistic Solutions</div>
  <nav>
    <a href="#home">Home</a>
    <a href="#services">Services</a>
    <a href="#portfolio">Portfolio</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section class="hero" id="home">
  <h1>We Design Brands That Attract Customers & Grow Businesses</h1>
  <p>Professional logo design, websites, and branding solutions for startups and small businesses.</p>
  <a href="#contact" class="btn">Get Free Quote</a>
</section>

<section class="section" id="services">
  <h2>Our Services</h2>
  <div class="cards">
    <div class="card">
      <h3>Logo Design</h3>
      <p>Modern and memorable logos for your brand identity.</p>
    </div>
    <div class="card">
      <h3>Website Design</h3>
      <p>Clean, responsive and fast business websites.</p>
    </div>
    <div class="card">
      <h3>Social Media Design</h3>
      <p>Posts and branding for Instagram & Facebook growth.</p>
    </div>
  </div>
</section>

<section class="section" id="portfolio">
  <h2>Portfolio</h2>
  <div class="portfolio">
    <div class="work">Sample Design 1</div>
    <div class="work">Sample Design 2</div>
    <div class="work">Sample Website 1</div>
  </div>
</section>

<section class="section" id="about">
  <h2>About Us</h2>
  <p>Artistic Solutions helps businesses build strong digital identity through creative design and modern web solutions.</p>
</section>

<section class="section" id="contact">
  <h2>Contact Us</h2>
  <div class="contact-box">
    <p>Email: contact.artisticsolutions@gmail.com</p>
    <p>WhatsApp: +92XXXXXXXXXX</p>
    <input type="text" placeholder="Your Name" />
    <input type="email" placeholder="Your Email" />
    <textarea placeholder="Your Message"></textarea>
    <button class="btn">Send Message</button>
  </div>
</section>

<footer>
  <p>© 2026 Artistic Solutions. All rights reserved.</p>
</footer>

<a class="whatsapp" href="https://wa.me/92XXXXXXXXXX" target="_blank">WhatsApp</a>

</body>
</html>
